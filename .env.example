# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: SQLite (fast, no setup)
DATABASE_URL=sqlite:///egx_radar.db
# Production: set this in Render env vars — Render injects it automatically via render.yaml

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Bot webhook auth ──────────────────────────────────────────────────────────
# This key must match the X-Bot-Api-Key header sent by egx_bot_v4.py
# In production: Render generates it automatically (render.yaml: generateValue: true)
# Copy the generated value into the bot's environment
BOT_API_KEY=dev-bot-key-change-me
